@article{farooqChangeHereChange2024,
    title = {The {{Change}} Is {{Here}}, and the {{Change}} Is {{Her}}: {{
             Pakistani American Representation}} in the {{Disney}}+ {{Series Ms}}
             . {{Marvel}}},
    shorttitle = {The {{Change}} Is {{Here}}, and the {{Change}} Is {{Her}}},
    author = {Farooq, Saadia and DeGalan, Anna},
    year = 2024,
    month = nov,
    journal = {Journal of Underrepresented \& Minority Progress},
    volume = {8},
    number = {SI(1)},
    issn = {2574-3481, 2574-3465},
    doi = {10.32674/j4m0nb38},
    urldate = {2026-07-13},
    abstract = {Ms. Marvel (2022) from the Marvel Cinematic Universe (MCU),
                adapted from the Marvel Comics series of the same name, follows a
                Muslim Pakistani American teenager from Jersey City who adores
                her hero, Captain Marvel. This paper engages with
                intersectionality of Kamala Khan's representation in Ms. Marvel
                through the lens of her multiple intersecting identities: as a
                Pakistani American, a Muslim, a teenage girl, and a superhero. We
                utilized Jos\'e Esteban Mu\~noz's theory of disidentification
                (1999) and bell hooks' critical feminist lens (i.e., her ideas of
                the dysmorphic body and the deconstruction of women as parts) to
                do a critical analysis of the six episodes, We found three
                changes from her comic book origins to the new superhero found in
                the Disney+ series: Kamala's powers, her character growth, and
                her identity as a Pakistani American teenager. The study
                discusses the intersectionality of Kamala's unique relationships
                on screen with her family, subverting typical cultural cues and
                gender roles, and her conformity and subversion of identity as a
                Muslim Pakistani American. while creating her new identity as a
                superheroine, all of which highlight the lived experiences of
                marginalized communities.},
}

